{
  "$schema": "https://raw.githubusercontent.com/nicegui/nicegui-tauri/v2/src-tauri/tauri.conf.json",
  "productName": "Claude Usage Tracker",
  "version": "0.10.1",
  "identifier": "com.claude-usage-tracker.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Claude Usage Tracker",
        "width": 440,
        "height": 700,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "center": true,
        "visible": false,
        "skipTaskbar": true
      },
      {
        "label": "mini",
        "url": "index.html#mini",
        "title": "",
        "width": 186,
        "height": 64,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true,
        "transparent": false
      },
      {
        "label": "analytics",
        "url": "index.html#analytics",
        "title": "Claude Usage — Analytics",
        "width": 960,
        "height": 720,
        "minWidth": 720,
        "minHeight": 520,
        "resizable": true,
        "decorations": true,
        "center": true,
        "visible": false
      },
      {
        "label": "todos",
        "url": "index.html#todos",
        "title": "Claude Usage — Tasks",
        "width": 1040,
        "height": 760,
        "minWidth": 640,
        "minHeight": 480,
        "resizable": true,
        "decorations": true,
        "center": true,
        "visible": false,
        "dragDropEnabled": false
      },
      {
        "label": "settings",
        "url": "index.html#settings",
        "title": "Claude Usage — Settings",
        "width": 680,
        "height": 780,
        "minWidth": 560,
        "minHeight": 540,
        "resizable": true,
        "decorations": true,
        "center": true,
        "visible": false
      }
    ],
    "trayIcon": {
      "id": "main-tray",
      "iconPath": "icons/icon.png",
      "iconAsTemplate": false,
      "tooltip": "Claude Usage Tracker"
    },
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "resources": {
      "../scripts/cli.mjs": "scripts/cli.mjs",
      "../scripts/cli/todos.mjs": "scripts/cli/todos.mjs",
      "../scripts/cli/phases.mjs": "scripts/cli/phases.mjs",
      "../scripts/cli/triage.mjs": "scripts/cli/triage.mjs",
      "../scripts/cli/hook.mjs": "scripts/cli/hook.mjs"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerHooks": "./windows/hooks.nsh"
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/DamirSadykov/Claude-Usage-Tracker-Windows/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDI2OTAzMzYyRjZGQ0Y1RUUKUldUdTlmejJZak9RSmhBWGEyVkl1UndaK3ZBM1JrN2pBNzJncWx3VVdRQU9mbENKR0JLeCtqNmMK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
